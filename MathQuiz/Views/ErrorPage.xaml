<Page x:Class="MathQuiz.Views.ErrorPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="ErrorPage" Foreground="White">

    <Grid>
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Width="600">
            <TextBlock TextWrapping="Wrap" FontSize="30" FontWeight="Bold" Foreground="Red" TextAlignment="Center" Margin="0,0,0,20" Height="94">
                🚨 !Error! 🚨<LineBreak/>
                    Sorry, something went wrong.
            </TextBlock>
            
            <Border Background="#2C3E50" CornerRadius="10" Padding="10" Margin="0,0,0,10">
                <StackPanel>
                    <TextBlock Text="Report error to Admin" FontSize="18" FontWeight="Bold" Margin="0,0,0,10"/>
                    <TextBox x:Name="ErrorDescription" Style="{StaticResource RoundedTextBoxStyle}" Height="120" ScrollViewer.CanContentScroll="True" FontSize="15" Padding="1" Margin="0,0,0,15" Foreground="#424242" Text="Please describe the error you encountered."/>
                    <Button x:Name="SendReportButton" Background="DodgerBlue" Content="Send " Style="{StaticResource ModernButtonStyle}" Width="100" FontSize="18" FontWeight="Bold" Padding="10" Click="SendReportButton_Click"/>
                    <TextBlock x:Name="ReportStatusText" FontSize="14" TextAlignment="Center" Margin="0,10,0,0"/>
                </StackPanel>
            </Border>

            <Button Content="Finish and Return to Menu" Style="{StaticResource ModernButtonStyle}" Background="Gray" FontSize="16" Width="250" Padding="10" Click="ReturnToMenu_Click"/>
        </StackPanel>
    </Grid>
</Page>