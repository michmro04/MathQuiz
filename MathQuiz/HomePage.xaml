<Page x:Class="MathQuiz.HomePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="HomePage">

    <Grid>
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
            <TextBlock Text="Math Quiz" FontSize="36" FontWeight="Bold" Foreground="White" TextAlignment="Center" Margin="0,0,0,40"/>

            <Button Content="Equations" Background="CornflowerBlue" Style="{StaticResource ModernButtonStyle}" Width="300" Height="50" FontSize="20" Margin="0,0,0,20" Click="EquationsButton_Click"/>

            <Button Content="Missing angle in polygons" Background="CornflowerBlue" Style="{StaticResource ModernButtonStyle}" Width="300" Height="50" FontSize="20" Click="MissingAngleButton_Click"/>
        </StackPanel>
    </Grid>
</Page>