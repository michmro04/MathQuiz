<Window x:Class="MathQuiz.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MathQuiz"
        mc:Ignorable="d"
        Title="MathQuiz" Height="450" Width="800"
        Foreground="White" Background="DimGray"
        FontFamily="Lucida Sans">
    
    <Grid>
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Width="720" Height="320">
            <TextBlock x:Name="ScoreText" Text="[score_text]" FontSize="13" HorizontalAlignment="Left" TextAlignment="Center" Margin="20,0,0,0"/>
            <TextBlock x:Name="EquationText" Text="[equation_text]" FontSize="18" TextAlignment="Center" Margin="0,50,0,20"/>
            <TextBox x:Name="AnswerInput" FontSize="20" TextAlignment="Center" Margin="0,0,0,10" Padding="5" Width="300" KeyDown="AnswerInput_KeyDown"/>
            <Button x:Name="CheckButton" Content="Sprawdź!" FontSize="16" Padding="10" Click="CheckButton_Click" Width="300"/>
            <TextBlock x:Name="FeedbackText" Text="[feedback_text]" Background="DarkGray" FontSize="16" Foreground="Black"  TextAlignment="Center" Margin="0,20,0,0" Width="223"/>
        </StackPanel>
    </Grid>
</Window>
