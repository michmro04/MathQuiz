<Window x:Class="MathQuiz.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MathQuiz"
        mc:Ignorable="d"
        Title="MathQuiz" Height="450" Width="800"
        Foreground="White" FontFamily="Lucida Sans">

    <Window.Resources>
        <Style x:Key="ModernButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#4CAF50"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="12">
                            <Border.Effect>
                                <DropShadowEffect Color="Black" BlurRadius="10" ShadowDepth="2" Opacity="0.3"/>
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#45a049"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="RoundedTextBoxStyle" TargetType="TextBox">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border CornerRadius="8" Background="White" BorderBrush="Transparent" Padding="5">
                            <ScrollViewer x:Name="PART_ContentHost"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Window.Background>
        <SolidColorBrush Color="#1E1E1E"/>
    </Window.Background>

    <Grid>
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Width="720" Height="320">
            <TextBlock x:Name="ScoreText" Text="[score_text]" FontSize="15" HorizontalAlignment="Left" TextAlignment="Center" Margin="20,0,0,0" FontWeight="Bold"/>
            <TextBlock x:Name="ExerciseText" Text="[exercise_text]" FontSize="26" TextAlignment="Left" Margin="0,0,0,10" FontWeight="SemiBold" Width="305"/>
            <TextBlock x:Name="EquationText" Text="[equation_text]" FontSize="26" TextAlignment="Center" Margin="0,10,0,20"/>
            <TextBox x:Name="AnswerInput" Style="{StaticResource RoundedTextBoxStyle}" FontSize="22" TextAlignment="Center" Margin="0,0,0,20" Padding="5" Width="300" KeyDown="AnswerInput_KeyDown" Foreground="Black"/>
            <Button x:Name="CheckButton" Content="Check!" Style="{StaticResource ModernButtonStyle}" FontSize="18" FontWeight="Bold" Padding="10" Click="CheckButton_Click" Width="300" Height="45"/>
            <TextBlock x:Name="FeedbackText" Text="[feedback_text]" FontSize="18" FontWeight="Bold" Foreground="White" TextAlignment="Center" Margin="0,25,0,0" Width="400"/>
        </StackPanel>
    </Grid>
</Window>