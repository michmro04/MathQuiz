<Page x:Class="MathQuiz.SuccessPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="SuccessPage" Foreground="White">

    <Grid>
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Width="600">
            <TextBlock TextWrapping="Wrap" FontSize="30" FontWeight="Bold" Foreground="LightGreen" TextAlignment="Center" Margin="0,0,0,20" Height="94">
    🎉               Congratulations! 🎉<LineBreak/>
                    You've reached your today's score goal!
            </TextBlock>
            <TextBlock Text="Resume of today's session:" HorizontalAlignment="Left" FontSize="20" FontWeight="SemiBold" TextAlignment="Center" Margin="20,0,0,5"/>

            <TextBlock x:Name="SummaryText" Text="[summarytext]" FontSize="15" TextAlignment="Center" HorizontalAlignment="Left" Margin="40,0,0,30" Foreground="LightGray" LineHeight="25"/>

            <Border Background="#2C3E50" CornerRadius="10" Padding="20" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="Send Report to Teacher" FontSize="18" FontWeight="Bold" Margin="0,0,0,10"/>
                    <TextBox x:Name="EmailInput" Style="{StaticResource RoundedTextBoxStyle}" FontSize="18" Padding="5" Margin="0,0,0,15" Foreground="#424242" Text="mrg.mrowicki@gmail.com"/>
                    <Button x:Name="SendEmailButton" Content="Send Message" Style="{StaticResource ModernButtonStyle}" Width="200" FontSize="18" FontWeight="Bold" Padding="10" Click="SendEmailButton_Click"/>
                    <TextBlock x:Name="EmailStatusText" FontSize="14" TextAlignment="Center" Margin="0,10,0,0"/>
                </StackPanel>
            </Border>

            <Button Content="Finish and Return to Menu" Style="{StaticResource ModernButtonStyle}" Background="Gray" FontSize="16" Width="250" Padding="10" Click="ReturnToMenu_Click"/>
        </StackPanel>
    </Grid>
</Page>